# Copy this file to .env and fill values locally.
# Do not commit .env or any raw secrets.

# Required for outbound calls.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Use either a rented Twilio Voice number or your verified caller ID.
# E.164 format only, for example +15551234567.
TWILIO_FROM_NUMBER=+15551234567

# Public HTTPS base URL for this server, usually from ngrok or Cloudflare Tunnel.
# Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=

# Pretty Good AI assessment number. The code refuses to call any other target.
PG_TARGET_NUMBER=+18054398008

# Deepgram handles live STT and TTS.
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# DeepSeek handles patient-dialogue reasoning and transcript analysis.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Runtime tuning.
APP_HOST=0.0.0.0
APP_PORT=8000
ARTIFACT_DIR=artifacts/calls
INITIAL_UTTERANCE_DELAY_SECONDS=4.0
MAX_CALL_SECONDS=210
RECORD_CALLS=true
